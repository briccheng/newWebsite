---
import Navbar from "../components/Navbar";
import ProjectCard from "../components/ProjectCard.astro";
import SocialIcons from "../components/SocialIcons.astro";
import { aboutText, education, experiences, navLinks, projects, skillGroups, socialLinks } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Brian Cheng | Software Engineer"
  description="Brian Cheng's portfolio website featuring experience, skills, projects, and contact information."
>
  <header class="site-header">
    <Navbar client:load links={navLinks} />
  </header>

  <main>
    <section id="home" class="hero section-shell">
      <div class="hero-copy">
        <p class="eyebrow">Software Engineer</p>
        <h1>Hi, I am Brian Cheng</h1>
        <p class="lead">Software Engineer eager to create impact</p>
        <p class="hero-summary">
          I build reliable software, practical automation, and developer-focused solutions with an emphasis on impact, clarity, and maintainability.
        </p>
        <div class="hero-actions">
          <a class="button" href="#projects">Explore Projects</a>
          <a class="button button-secondary" href={socialLinks.resume} target="_blank" rel="noreferrer">
            View Resume
          </a>
        </div>
        <SocialIcons links={socialLinks} />
      </div>

      <div class="hero-visual panel">
        <img src="/profile-placeholder.svg" alt="Illustrated placeholder portrait for Brian Cheng" />
      </div>
    </section>

    <section id="about" class="section-shell">
      <div class="section-heading">
        <span>About</span>
        <h2>Engineering experience shaped by testing, delivery, and product impact.</h2>
        <p>{aboutText}</p>
      </div>
      <div class="about-grid">
        <article class="panel about-card">
          <h3>What I focus on</h3>
          <p>
            I enjoy building systems that remove friction for users and engineering teams, especially where thoughtful tooling and clean implementation can create lasting leverage.
          </p>
        </article>
        <article class="panel about-card">
          <h3>Current direction</h3>
          <p>
            My work increasingly sits at the intersection of software engineering, automation, and applied AI, with attention to practical results rather than novelty for its own sake.
          </p>
        </article>
      </div>
      <a class="button" href={socialLinks.resume} target="_blank" rel="noreferrer">View Resume</a>
    </section>

    <section id="experience" class="section-shell">
      <div class="section-heading">
        <span>Experience</span>
        <h2>Professional work centered on automation, quality, and delivery.</h2>
        <p>Representative milestones across industry engineering work and hands-on software development.</p>
      </div>
      <div class="timeline">
        {experiences.map((item) => (
          <article class="timeline-item">
            <div class="timeline-marker" aria-hidden="true"></div>
            <div class="timeline-card panel">
              <img class="timeline-logo" src={item.logoSrc} alt={item.logoAlt} />
              <div class="timeline-copy">
                <div class="timeline-meta">
                  <h3>{item.company}</h3>
                  <span>{item.duration}</span>
                </div>
                <p class="timeline-role">{item.role}</p>
                <p>{item.description}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="education" class="section-shell">
      <div class="section-heading">
        <span>Education</span>
        <h2>Academic foundations in computer science and computer engineering.</h2>
        <p>Graduate and undergraduate training shown in the same timeline style as experience for a consistent reading flow.</p>
      </div>
      <div class="timeline">
        {education.map((item) => (
          <article class="timeline-item">
            <div class="timeline-marker" aria-hidden="true"></div>
            <div class="timeline-card panel">
              <img class="timeline-logo" src={item.logoSrc} alt={item.logoAlt} />
              <div class="timeline-copy">
                <div class="timeline-meta">
                  <h3>{item.school}</h3>
                  <span>{item.duration}</span>
                </div>
                <p class="timeline-role">{item.degree}</p>
                <p class="timeline-subheading">Relevant courses</p>
                <ul class="course-list">
                  {item.courses.map((course) => <li>{course}</li>)}
                </ul>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="skills" class="section-shell">
      <div class="section-heading">
        <span>Skills</span>
        <h2>Languages, frameworks, and AI tooling I work with.</h2>
        <p>Grouped to reflect the stack I use most often across product engineering, test automation, and experimentation.</p>
      </div>
      <div class="skills-grid">
        {skillGroups.map((group) => (
          <article class="panel skill-card">
            <h3>{group.title}</h3>
            <ul>
              {group.items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section id="projects" class="section-shell">
      <div class="section-heading">
        <span>Projects</span>
        <h2>Selected work across automation, AI, and full-stack development.</h2>
        <p>Each card is designed to be easy to swap with final screenshots and direct project links as the portfolio evolves.</p>
      </div>
      <div class="projects-grid">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>
  </main>

  <footer id="contact" class="footer section-shell">
    <div class="footer-panel panel">
      <div class="section-heading footer-heading">
        <span>Contact</span>
        <h2>Get in Touch</h2>
        <p>
          If you want to learn more about my work, please reach out via email:
          <a class="email-link" href={socialLinks.email}> bricheng.job@gmail.com</a>
        </p>
      </div>
      <hr />
      <div class="footer-bottom">
        <SocialIcons links={socialLinks} includeResume={true} includeEmail={true} />
        <p>Created by Brian Cheng</p>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    padding-top: 0.35rem;
  }

  .hero {
    display: grid;
    gap: 2rem;
    align-items: center;
    min-height: calc(100vh - 5rem);
    padding-top: 3.2rem;
  }

  .hero-copy {
    display: grid;
    gap: 1.25rem;
    max-width: 42rem;
  }

  .hero h1 {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: clamp(3rem, 8vw, 5.8rem);
    line-height: 0.96;
    letter-spacing: -0.04em;
  }

  .hero-summary {
    max-width: 36rem;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .button-secondary {
    background: rgba(11, 18, 32, 0.08);
    color: var(--surface-strong);
  }

  .button-secondary:hover,
  .button-secondary:focus-visible {
    background: rgba(11, 18, 32, 0.14);
  }

  .hero-visual {
    overflow: hidden;
    padding: 1rem;
  }

  .hero-visual img {
    width: 100%;
    border-radius: 1.25rem;
  }

  .about-grid,
  .skills-grid,
  .projects-grid {
    display: grid;
    gap: 1.25rem;
  }

  .about-grid {
    margin-bottom: 1.5rem;
  }

  .about-card,
  .skill-card {
    padding: 1.6rem;
  }

  .about-card h3,
  .skill-card h3 {
    margin-bottom: 0.7rem;
    font-size: 1.2rem;
  }

  .about-card p,
  .skill-card li {
    color: var(--muted);
  }

  .skill-card ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    padding: 0;
    list-style: none;
  }

  .skill-card li {
    padding: 0.55rem 0.85rem;
    border-radius: 999px;
    background: rgba(180, 82, 9, 0.08);
    font-weight: 700;
  }

  .timeline {
    position: relative;
    display: grid;
    gap: 1.5rem;
  }

  .timeline::before {
    content: "";
    position: absolute;
    top: 0.8rem;
    left: 1.05rem;
    bottom: 0.8rem;
    width: 2px;
    background: linear-gradient(180deg, rgba(180, 82, 9, 0.45), rgba(15, 118, 110, 0.45));
  }

  .timeline-item {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    align-items: start;
  }

  .timeline-marker {
    position: relative;
    z-index: 1;
    width: 2.1rem;
    height: 2.1rem;
    margin-top: 1rem;
    border: 6px solid #f8f4ec;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--brand), var(--accent));
    box-shadow: 0 8px 18px rgba(11, 18, 32, 0.14);
  }

  .timeline-card {
    display: grid;
    gap: 1rem;
    padding: 1.35rem;
  }

  .timeline-logo {
    width: 4rem;
    height: 4rem;
    border-radius: 1rem;
  }

  .timeline-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    align-items: center;
    justify-content: space-between;
  }

  .timeline-meta h3 {
    font-size: 1.25rem;
  }

  .timeline-meta span,
  .timeline-role,
  .timeline-copy p:last-child {
    color: var(--muted);
  }

  .timeline-role {
    font-weight: 700;
  }

  .timeline-subheading {
    margin-top: 0.35rem;
    color: var(--surface-strong);
    font-size: 0.95rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .course-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    padding: 0;
    margin-top: 0.85rem;
    list-style: none;
  }

  .course-list li {
    padding: 0.5rem 0.8rem;
    border-radius: 999px;
    background: rgba(15, 118, 110, 0.08);
    color: var(--muted);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .footer {
    width: min(calc(100% - 2rem), var(--max-width));
    margin: 0 auto 3rem;
    padding-top: 0;
  }

  .footer-panel {
    padding: 2rem;
  }

  .footer-panel hr {
    border: 0;
    border-top: 1px solid var(--line);
    margin: 1.25rem 0 1.5rem;
  }

  .footer-heading {
    margin-bottom: 0;
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
  }

  .footer-bottom p,
  .email-link {
    color: var(--muted);
  }

  .email-link {
    font-weight: 700;
  }

  @media (min-width: 760px) {
    .hero {
      grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    }

    .about-grid,
    .skills-grid,
    .projects-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 980px) {
    .skills-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .projects-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .timeline-card {
      grid-template-columns: auto 1fr;
      align-items: start;
    }
  }

  @media (max-width: 759px) {
    .hero {
      min-height: auto;
    }

    .timeline::before {
      left: 1rem;
    }

    .timeline-meta {
      justify-content: flex-start;
    }

    .footer-panel {
      padding: 1.5rem;
    }
  }
</style>
