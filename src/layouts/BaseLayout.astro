---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@500;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --background: #f8f4ec;
    --background-strong: #f3ebdd;
    --surface: rgba(255, 255, 255, 0.78);
    --surface-strong: #0b1220;
    --muted: #4f5b70;
    --brand: #b45209;
    --brand-dark: #8a3b04;
    --accent: #0f766e;
    --line: rgba(11, 18, 32, 0.1);
    --shadow: 0 22px 60px rgba(11, 18, 32, 0.12);
    --max-width: 76rem;
    color-scheme: light;
    scroll-behavior: smooth;
  }

  * {
    box-sizing: border-box;
    margin: 0;
  }

  html {
    background:
      radial-gradient(circle at top left, rgba(180, 82, 9, 0.16), transparent 30%),
      radial-gradient(circle at top right, rgba(15, 118, 110, 0.16), transparent 26%),
      linear-gradient(180deg, #fbf8f2 0%, #f8f4ec 45%, #f3ede2 100%);
    color: var(--surface-strong);
    font-family: "Manrope", sans-serif;
  }

  body {
    min-height: 100vh;
    line-height: 1.6;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  main {
    width: min(calc(100% - 2rem), var(--max-width));
    margin: 0 auto;
    padding: 1rem 0 5rem;
  }

  section {
    scroll-margin-top: 6rem;
  }

  .section-shell {
    position: relative;
    padding: 5rem 0;
  }

  .section-heading {
    display: grid;
    gap: 0.8rem;
    max-width: 40rem;
    margin-bottom: 2.5rem;
  }

  .section-heading span {
    color: var(--brand);
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .section-heading h2 {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: clamp(2rem, 3vw, 3.25rem);
    line-height: 1.05;
  }

  .section-heading p,
  p.lead {
    color: var(--muted);
    font-size: 1.05rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.25rem;
    padding: 0.9rem 1.3rem;
    border-radius: 999px;
    background: var(--brand);
    color: white;
    font-weight: 700;
    transition: transform 180ms ease, background 180ms ease;
  }

  .button:hover,
  .button:focus-visible {
    transform: translateY(-2px);
    background: var(--brand-dark);
    outline: none;
  }

  .eyebrow {
    color: var(--brand);
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .panel {
    border: 1px solid var(--line);
    border-radius: 1.75rem;
    background: var(--surface);
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .nav-shell {
    width: min(calc(100% - 2rem), var(--max-width));
    margin: 1rem auto 0;
    padding: 0.9rem 1rem;
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    border: 1px solid rgba(11, 18, 32, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(18px);
    box-shadow: 0 14px 30px rgba(11, 18, 32, 0.06);
  }

  .brand {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 0.98rem;
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .nav-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.4rem;
    padding: 0;
    list-style: none;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.6rem;
    padding: 0.55rem 0.95rem;
    border-radius: 999px;
    color: var(--muted);
    font-size: 0.96rem;
    font-weight: 700;
    transition: background 180ms ease, color 180ms ease;
  }

  .nav-link:hover,
  .nav-link:focus-visible,
  .nav-link.active {
    background: rgba(180, 82, 9, 0.12);
    color: var(--surface-strong);
    outline: none;
  }

  @media (max-width: 760px) {
    .nav-shell {
      border-radius: 1.5rem;
      align-items: flex-start;
      flex-direction: column;
    }

    .nav-list {
      justify-content: flex-start;
    }

    .section-shell {
      padding: 4rem 0;
    }
  }
</style>
